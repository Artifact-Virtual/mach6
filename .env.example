# Mach6 — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── LLM Providers ──────────────────────────────────────────────────────────

# Anthropic (claude-opus-4-6, claude-sonnet-4, etc.)
ANTHROPIC_API_KEY=

# OpenAI (gpt-4o, o3-mini, etc.)
OPENAI_API_KEY=

# GitHub Copilot — usually resolved automatically via `gh auth login`.
# Only set these if automatic resolution fails.
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=

# ── HTTP API ────────────────────────────────────────────────────────────────
# Secret token required to call POST /api/v1/chat
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MACH6_API_KEY=

# ── Discord ─────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── Web UI / Server ─────────────────────────────────────────────────────────
# Port for the web UI and HTTP API (default: 3006)
MACH6_PORT=3006

# ── Timezone ────────────────────────────────────────────────────────────────
# Timezone string for the agent's clock (default: system timezone)
# TZ=America/New_York
# TZ=Asia/Karachi
# TZ=Europe/London
