# ═══════════════════════════════════════════════════════════
# Mach6 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Or run `npx mach6 init` to generate this interactively.
# .env is gitignored — never commit secrets.
# ═══════════════════════════════════════════════════════════

# ── LLM Providers ──────────────────────────────────────────

# Anthropic (Claude Opus, Sonnet, etc.)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, o3-mini, etc.)
OPENAI_API_KEY=

# GitHub Copilot — usually resolved automatically via `gh auth login`.
# Only set these if automatic resolution fails.
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=

# ── Channels ───────────────────────────────────────────────

# Discord bot token — from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord application (client) ID
DISCORD_CLIENT_ID=

# ── HTTP API ───────────────────────────────────────────────

# Secret token required to call POST /api/v1/chat
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MACH6_API_KEY=

# ── Server ─────────────────────────────────────────────────

# Port for the web UI and HTTP API (default: 3006)
MACH6_PORT=3006

# ── Timezone ───────────────────────────────────────────────

# Override system timezone for the agent's clock
# TZ=America/New_York
# TZ=Asia/Karachi
# TZ=Europe/London
